# Database - PostgreSQL (Supabase / Neon / RDS)
# Use transaction connection pooler (e.g. port 6543 on Supabase) for Vercel Serverless
DATABASE_URL="postgresql://user:password@host:6543/db?pgbouncer=true"

# Use direct connection (e.g. port 5432) for Prisma migrations
DIRECT_URL="postgresql://user:password@host:5432/db"

# NextAuth
AUTH_SECRET="your-secret-key-generate-with-openssl-rand-base64-32"
AUTH_TRUST_HOST=true
NEXTAUTH_URL="https://your-vercel-domain.vercel.app"

# App
NEXT_PUBLIC_APP_URL="https://your-vercel-domain.vercel.app"
NEXT_PUBLIC_APP_NAME="AtomQuest"
